# Copy this file to .env.local and fill in your Supabase credentials
# Get these from: https://supabase.com → Your Project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Admin email address (only this email can access /admin, also receives new booking notifications)
ADMIN_EMAIL=your-admin-email@example.com

# Resend — for sending booking emails (free at resend.com)
RESEND_API_KEY=re_xxxxxxxxxx

# Email sender — must match a verified domain in Resend
# While testing you can use: Ania's Salon <onboarding@resend.dev>
FROM_EMAIL=Ania's Salon <hello@yourdomain.com>

# Optional: shown in email footer
SALON_PHONE=+44 7700 000000
SALON_ADDRESS=123 Beauty Lane, Your Town
